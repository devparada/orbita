---

<div class="hud-container">
  <div class="top-bar">
    <div class="logo">
      <span class="dot"></span>
      <h1>ÓRBITA</h1>
    </div>
    <div class="status">SISTEMA: ACTIVO</div>
  </div>

  <div class="bottom-bar">
    <p>DATOS EN TIEMPO REAL // NASA API</p>
    <div class="scanline"></div>
  </div>
</div>

<style>
  .hud-container {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 10;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    font-family: 'Courier New', Courier, monospace;
    color: #00ffcc;
  }

  .top-bar {
    display: flex;
    justify-content: space-between;
    border-bottom: 1px solid rgba(0, 255, 204, 0.3);
    padding-bottom: 0.5rem;
  }

  .top-bar, .bottom-bar {
    border: none;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
  }

  .logo { display: flex; align-items: center; gap: 10px; }
  .logo h1 { font-size: 1.5rem; margin: 0; letter-spacing: 4px; }
  .dot { width: 8px; height: 8px; background: #00ffcc; border-radius: 50%; box-shadow: 0 0 10px #00ffcc; }

  .bottom-bar {
    font-size: 0.8rem;
    border-top: 1px solid rgba(0, 255, 204, 0.3);
    padding-top: 0.5rem;
  }

  .scanline {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 2px;
    background: rgba(0, 255, 204, 0.1);
    animation: scan 4s linear infinite;
  }

  @keyframes scan {
    from { top: 0%; }
    to { top: 100%; }
  }
</style>