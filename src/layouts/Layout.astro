---
import HUD from "../components/ui/HUD.astro";

interface Props {
	title?: string;
}

const { title = "ÓRBITA | NASA NEO Visualizer" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <HUD />
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  :root {
    --primary-glow: #00ffcc;
  }

  body, html {
    margin: 0;
    padding: 0;
    background: #000;
    width: 100%;
    height: 100%;
    overflow: hidden;
    color: white;
  }

  main {
    width: 100vw;
    height: 100vh;
  }
</style>